# KEY Protocol Deployment Environment
# Copy to .env.example and fill in values before deploying.
# Never commit the filled-in file.

# Private key of the deployer wallet (hex, no 0x prefix)
DEPLOYER_KEY=PRIVATE-KEY

# Address that receives the immutable protocol fee (0.3% default)
# Use a multisig or Safe, cannot be changed post-deployment
PROTOCOL_TREASURY=0x86076aBcB9492359fd78432242A3534Fd114552B

# Protocol fee
PROTOCOL_FEE_BPS=30

# Ethereum mainnet RPC
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Contract verification Etherscan API key
ETHERSCAN_API_KEY=YOUR-KEY-HERE